generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Topic {
  ARRAYS
  STRINGS
  LINKED_LISTS
  STACK
  QUEUE
  TREES
  BST
  GRAPHS
  DP
  GREEDY
  BACKTRACKING
  SLIDING_WINDOW
  BINARY_SEARCH
  HEAP
  TRIE
  HASHMAP
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum ChatRole {
  USER
  ASSISTANT
}

model User {
  id                String          @id @default(cuid())
  username          String?         @unique
  name              String
  email             String          @unique
  password          String
  resetToken        String?
  resetTokenExpiry  DateTime?
  currentStreak     Int             @default(0)
  longestStreak     Int             @default(0)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  
  refreshTokens     RefreshToken[]
  solvedProblems    SolvedProblem[]
  problemAttempts   ProblemAttempt[]
  problemNotes      ProblemNote[]
  studyPlans        StudyPlan[]
  contests          Contest[]
  chatMessages      ChatMessage[]
  leetCodeStats     LeetCodeStats?
  topicMasteries    TopicMastery[]
  codeReviews       CodeReview[]
  companyPreps      CompanyPrep[]
  achievements      Achievement[]

  @@index([email])
  @@index([username])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
}

model Problem {
  id             String          @id @default(cuid())
  title          String
  difficulty     Difficulty
  topic          Topic
  leetcodeUrl    String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  solvedProblems SolvedProblem[]
  problemAttempts ProblemAttempt[]
  problemNotes   ProblemNote[]
  codeReviews    CodeReview[]

  @@index([difficulty])
  @@index([topic])
}

model SolvedProblem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  solvedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
  @@index([solvedAt])
}

model ProblemAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId   String
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  status      String   // e.g., "SUCCESS", "FAILED"
  solveTime   Int?     // in seconds
  hintsUsed   Int      @default(0)
  difficulty  Difficulty
  topic       Topic
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([problemId])
  @@index([createdAt])
}

model ProblemNote {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId     String
  problem       Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  approach      String?  @db.Text
  mistakes      String?  @db.Text
  revisionNotes String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, problemId])
  @@index([userId])
  @@index([problemId])
}

model LeetCodeStats {
  id               String   @id @default(cuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leetcodeUsername String
  totalSolved      Int      @default(0)
  easySolved       Int      @default(0)
  mediumSolved     Int      @default(0)
  hardSolved       Int      @default(0)
  contestRating    Float?
  ranking          Int?
  lastSyncedAt     DateTime @default(now())

  @@index([userId])
}

model TopicMastery {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic       Topic
  masteryPct  Float    @default(0)
  solvedCount Int      @default(0)
  updatedAt   DateTime @updatedAt

  @@unique([userId, topic])
  @@index([userId])
}

model CodeReview {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId       String
  problem         Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  language        String
  code            String   @db.Text
  timeComplexity  String?
  spaceComplexity String?
  score           Float?
  feedback        String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([problemId])
}

model CompanyPrep {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName    String
  completedCount Int      @default(0)
  totalCount     Int
  readinessScore Float?
  updatedAt      DateTime @updatedAt

  @@unique([userId, companyName])
  @@index([userId])
}

model Achievement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeName   String
  description String?  @db.Text
  earnedAt    DateTime @default(now())

  @@unique([userId, badgeName])
  @@index([userId])
}

model StudyPlan {
  id            String     @id @default(cuid())
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String     @db.Text
  skillLevel    SkillLevel
  targetCompany String?
  hoursPerWeek  Int
  roadmap       Json?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([userId])
}

model Contest {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  contestName String
  ranking     Int?
  rating      Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([rating])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ChatRole
  content   String   @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}
